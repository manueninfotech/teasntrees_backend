# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/teasntrees_backend

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production_minimum_64_chars
JWT_EXPIRE=30d

# OTP Configuration
OTP_EXPIRY_MINUTES=5
MAX_OTP_ATTEMPTS=5

# Firebase Configuration
FIREBASE_SERVICE_ACCOUNT=your_firebase_service_account

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Admin IP Whitelist (comma-separated, leave empty in development)
ADMIN_WHITELIST_IPS=your_whitelist_ips

# Razorpay
RAZORPAY_KEY_ID=your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# Performance Monitoring
ENABLE_PERFORMANCE_MONITORING=false


